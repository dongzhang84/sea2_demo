        {
          "offset_hex": "0x0201",
          "selector": 1,
          "cc_arg": 18,
          "speaker": "$s公爵",
          "text_id": 50,
          "text": "洛克，洛克在嗎？"
        },
        {
          "offset_hex": "0x020a",
          "selector": 2,
          "cc_arg": 31,
          "speaker": "老水手洛克",
          "text_id": 51,
          "text": "〔老水手洛克〕\\n我在這裡．"
        },
        {
          "offset_hex": "0x0213",
          "selector": 1,
          "cc_arg": 18,
          "speaker": "$s公爵",
          "text_id": 52,
          "text": "我任命你為$n的教官，希望你把他鍛鍊成好水手．"
        },
        {
          "offset_hex": "0x021c",
          "selector": 2,
          "cc_arg": 31,
          "speaker": "老水手洛克",
          "text_id": 53,
          "text": "知道了，船長，啊！不對，公爵閣下．"
        },
        {
          "offset_hex": "0x0225",
          "selector": 1,
          "cc_arg": 18,
          "speaker": "$s公爵",
          "text_id": 54,
          "text": "不要因為他是我的兒子而客氣，要充分讓他鍛鍊啊！"
        }
      ]
    },
