      ],
      "records": [
        {
          "offset_hex": "0x05d4",
          "selector": 1,
          "cc_arg": 31,
          "speaker": "老水手洛克",
          "text_id": 139,
          "text": "少爺，沒有資金就無法出航．那家酒店的老闆娘曾經照顧過公爵，找她商量一下不好嗎？"
        }
      ]
    },
    {
      "id": "Snr1.chunk0.sub0.run29",
