digraph joao_opening_topology {
  graph [rankdir=LR];
  node [shape=box, fontname="Menlo"];
  item_000 [label="Snr1.chunk0.sub0.run0\ntext 0..0\nspeakers 管家麥克\n管家麥克"];
  item_001 [label="Snr1.chunk0.sub0.run1\ntext 1..17\nspeakers $s公爵夫人, 老水手洛克\n$s公爵夫人 / 老水手洛克"];
  item_000 -> item_001 [label="bytecode next"];
  item_002 [label="Snr1.chunk0.sub0.run2\ntext 18..18\nspeakers 管家麥克\n管家麥克"];
  item_001 -> item_002 [label="bytecode next"];
  item_003 [label="Snr1.chunk0.sub0.run3\ntext 19..21\nspeakers 管家麥克\n管家麥克"];
  item_002 -> item_003 [label="bytecode next"];
  item_004 [label="Snr1.chunk0.sub0.run4\ntext 22..49\nspeakers $s公爵\n$s公爵"];
  item_003 -> item_004 [label="bytecode next"];
  item_005 [label="Snr1.chunk0.sub0.run5\ntext 50..54\nspeakers $s公爵, 老水手洛克\n$s公爵 / 老水手洛克"];
  item_004 -> item_005 [label="bytecode next"];
  item_006 [label="Snr1.chunk0.sub0.run6\ntext 55..55\nspeakers 紅鯨亭女老闆卡蕾珞娃\n紅鯨亭女老闆卡蕾珞娃"];
  item_005 -> item_006 [label="bytecode next"];
  item_007 [label="Snr1.chunk0.sub0.run7\ntext 56..59\nspeakers 紅鯨亭女老闆卡蕾珞娃, 歌女路琪亞\n紅鯨亭女老闆卡蕾珞娃 / 歌女路琪亞"];
  item_006 -> item_007 [label="bytecode next"];
  item_008 [label="Snr1.chunk0.sub0.run8\ntext 60..62\nspeakers 紅鯨亭女老闆卡蕾珞娃, 歌女路琪亞\n紅鯨亭女老闆卡蕾珞娃 / 歌女路琪亞"];
  item_007 -> item_008 [label="bytecode next"];
  item_009 [label="Snr1.chunk0.sub0.run9\ntext 63..63\nspeakers 歌女路琪亞\n歌女路琪亞"];
  item_008 -> item_009 [label="bytecode next"];
  item_010 [label="Snr1.chunk0.sub0.run10\ntext 64..77\nspeakers 紅鯨亭女老闆卡蕾珞娃, 歌女路琪亞, 老水手洛克\n紅鯨亭女老闆卡蕾珞娃 / 歌女路琪亞 / 老水手洛克"];
  item_009 -> item_010 [label="bytecode next"];
  item_011 [label="Snr1.chunk0.sub0.run11\ntext 78..82\nspeakers 老水手洛克, 歌女路琪亞\n老水手洛克 / 歌女路琪亞"];
  item_010 -> item_011 [label="bytecode next"];
  item_012 [label="Snr1.chunk0.sub0.run12\ntext 83..86\nspeakers 歌女路琪亞, 老水手洛克\n歌女路琪亞 / 老水手洛克"];
  item_011 -> item_012 [label="bytecode next"];
  item_013 [label="Snr1.chunk0.sub0.short44\nshort text 87\n哎呀，是$n先生呀，$s公爵正在找您呢．"];
  item_012 -> item_013 [label="bytecode next"];
  item_014 [label="Snr1.chunk0.sub0.short45\nshort text 88\n$n先生，公爵閣下有令要把您當作平民對待，所以請您不要再來皇宮了．"];
  item_013 -> item_014 [label="bytecode next"];
  item_015 [label="Snr1.chunk0.sub0.short46\nshort text 89\n$n先生，回公爵府了嗎？"];
  item_014 -> item_015 [label="bytecode next"];
  item_016 [label="Snr1.chunk0.sub0.short47\nshort text 90\n〔菲利普主教〕\\n哎唷，$n先生，$s公爵家有人要去航海嗎？"];
  item_015 -> item_016 [label="bytecode next"];
  item_017 [label="Snr1.chunk0.sub0.run13\ntext 91..91\nspeakers -\nJoão self/default lines"];
  item_016 -> item_017 [label="bytecode next"];
  item_018 [label="Snr1.chunk0.sub0.short48\nshort text 92\n其實，我是來找有經驗的水手的．嘿，真難找．"];
  item_017 -> item_018 [label="bytecode next"];
  item_019 [label="Snr1.chunk0.sub0.short49\nshort text 93\n啊，想起來了，從公爵府來的洛克先生正找您呢！"];
  item_018 -> item_019 [label="bytecode next"];
  item_020 [label="Snr1.chunk0.sub0.run14\ntext 94..94\nspeakers -\nJoão self/default lines"];
  item_019 -> item_020 [label="bytecode next"];
  item_021 [label="Snr1.chunk0.sub0.short50\nshort text 95\n噢，$n先生，恩里克神父的事就拜託您啦．"];
  item_020 -> item_021 [label="bytecode next"];
  item_022 [label="Snr1.chunk0.sub0.short51\nshort text 96\n另外，請把這些金幣作為資金的一部分使用吧．"];
  item_021 -> item_022 [label="bytecode next"];
  item_023 [label="Snr1.chunk0.sub0.run15\ntext 98..98\nspeakers -\nJoão self/default lines"];
  item_022 -> item_023 [label="bytecode next"];
  item_024 [label="Snr1.chunk0.sub0.run16\ntext 99..100\nspeakers -\nJoão self/default lines"];
  item_023 -> item_024 [label="bytecode next"];
  item_025 [label="Snr1.chunk0.sub0.short52\nshort text 101\n噢，您是虔誠的人．上帝會保佑您的！"];
  item_024 -> item_025 [label="bytecode next"];
  item_026 [label="Snr1.chunk0.sub0.run17\ntext 102..102\nspeakers -\nJoão self/default lines"];
  item_025 -> item_026 [label="bytecode next"];
  item_027 [label="Snr1.chunk0.sub0.short53\nshort text 103\n噢，您真謙虛啊！"];
  item_026 -> item_027 [label="bytecode next"];
  item_028 [label="Snr1.chunk0.sub0.short54\nshort text 104\n〔菲利普主教〕\\n噢，$n先生，感謝您光臨．"];
  item_027 -> item_028 [label="bytecode next"];
  item_029 [label="Snr1.chunk0.sub0.run18\ntext 105..105\nspeakers -\nJoão self/default lines"];
  item_028 -> item_029 [label="bytecode next"];
  item_030 [label="Snr1.chunk0.sub0.short55\nshort text 106\n是啊，我要拜託您辦點事．"];
  item_029 -> item_030 [label="bytecode next"];
  item_031 [label="Snr1.chunk0.sub0.run19\ntext 107..107\nspeakers -\nJoão self/default lines"];
  item_030 -> item_031 [label="bytecode next"];
  item_032 [label="Snr1.chunk0.sub0.short56\nshort text 108\n是啊，我聽說$n先生要出海，是嗎？"];
  item_031 -> item_032 [label="bytecode next"];
  item_033 [label="Snr1.chunk0.sub0.short57\nshort text 109\n尋找傳說中的普萊斯特·約翰王國是我們基督教徒的使命，祝您成功．"];
  item_032 -> item_033 [label="bytecode next"];
  item_034 [label="Snr1.chunk0.sub0.short58\nshort text 110\n還有一件事，我有個宿願，希望您能幫我實現．"];
  item_033 -> item_034 [label="bytecode next"];
  item_035 [label="Snr1.chunk0.sub0.short59\nshort text 111\n恩里克，恩里克神父，這邊來．"];
  item_034 -> item_035 [label="bytecode next"];
  item_036 [label="Snr1.chunk0.sub0.run20\ntext 112..112\nspeakers 恩里克神父\n恩里克神父"];
  item_035 -> item_036 [label="bytecode next"];
  item_037 [label="Snr1.chunk0.sub0.short60\nshort text 113\n這是從弗朗西斯科會派遣來的傳教士，叫恩里克．"];
  item_036 -> item_037 [label="bytecode next"];
  item_038 [label="Snr1.chunk0.sub0.short61\nshort text 114\n$n先生，您可能知道法王廳想向東方傳教吧．"];
  item_037 -> item_038 [label="bytecode next"];
  item_039 [label="Snr1.chunk0.sub0.short62\nshort text 115\n拜託您把他送到日本吧．"];
  item_038 -> item_039 [label="bytecode next"];
  item_040 [label="Snr1.chunk0.sub0.run21\ntext 116..121\nspeakers 恩里克神父\n恩里克神父"];
  item_039 -> item_040 [label="bytecode next"];
  item_041 [label="Snr1.chunk0.sub0.run22\ntext 122..124\nspeakers 老水手洛克\n老水手洛克"];
  item_040 -> item_041 [label="bytecode next"];
  item_042 [label="Snr1.chunk0.sub0.short63\nshort text 125\n少爺，我是受$s公爵之命造船的，到底是哪位要用這條船呀？"];
  item_041 -> item_042 [label="bytecode next"];
  item_043 [label="Snr1.chunk0.sub0.run23\ntext 126..126\nspeakers -\nJoão self/default lines"];
  item_042 -> item_043 [label="bytecode next"];
  item_044 [label="Snr1.chunk0.sub0.short64\nshort text 127\n對了，想起來了．洛克正找您呢，說要您回公爵府．"];
  item_043 -> item_044 [label="bytecode next"];
  item_045 [label="Snr1.chunk0.sub0.run24\ntext 128..128\nspeakers 老水手洛克\n老水手洛克"];
  item_044 -> item_045 [label="bytecode next"];
  item_046 [label="Snr1.chunk0.sub0.short65\nshort text 129\n原來是你呀，洛克，已經造好了．"];
  item_045 -> item_046 [label="bytecode next"];
  item_047 [label="Snr1.chunk0.sub0.short66\nshort text 130\n按照萊昂公爵的命令，要把它造成同公爵首次坐的船一樣的拉丁級船．"];
  item_046 -> item_047 [label="bytecode next"];
  item_048 [label="Snr1.chunk0.sub0.short67\nshort text 131\n船名是『海盧梅思2世』，是一種三角帆船，它易於操縱，適於初學者．"];
  item_047 -> item_048 [label="bytecode next"];
  item_049 [label="Snr1.chunk0.sub0.short68\nshort text 133\n$n先生，你如果有什麼困難就去酒館吧．"];
  item_048 -> item_049 [label="bytecode next"];
  item_050 [label="Snr1.chunk0.sub0.short69\nshort text 134\n那家的老闆娘叫卡蕾珞娃，聽說令尊年輕時曾得到過她的幫助．"];
  item_049 -> item_050 [label="bytecode next"];
  item_051 [label="Snr1.chunk0.sub0.run25\ntext 135..135\nspeakers 老水手洛克\n老水手洛克"];
  item_050 -> item_051 [label="bytecode next"];
  item_052 [label="Snr1.chunk0.sub0.short70\nshort text 136\n$n先生，菲利普主教正找您呢．"];
  item_051 -> item_052 [label="bytecode next"];
  item_053 [label="Snr1.chunk0.sub0.run26\ntext 137..137\nspeakers -\nJoão self/default lines"];
  item_052 -> item_053 [label="bytecode next"];
  item_054 [label="Snr1.chunk0.sub0.run27\ntext 138..138\nspeakers -\nJoão self/default lines"];
  item_053 -> item_054 [label="bytecode next"];
  item_055 [label="Snr1.chunk0.sub0.run28\ntext 139..139\nspeakers 老水手洛克\n老水手洛克"];
  item_054 -> item_055 [label="bytecode next"];
  item_056 [label="Snr1.chunk0.sub0.run29\ntext 140..140\nspeakers 老水手洛克\n老水手洛克"];
  item_055 -> item_056 [label="bytecode next"];
  item_057 [label="Snr1.chunk0.sub0.run30\ntext 141..141\nspeakers 老水手洛克\n老水手洛克"];
  item_056 -> item_057 [label="bytecode next"];
  item_058 [label="Snr1.chunk0.sub0.run31\ntext 142..157\nspeakers 老水手洛克, 恩里克神父\n老水手洛克 / 恩里克神父"];
  item_057 -> item_058 [label="bytecode next"];
  item_059 [label="Snr1.chunk0.sub0.run32\ntext 158..158\nspeakers 老水手洛克\n老水手洛克"];
  item_058 -> item_059 [label="bytecode next"];
  item_060 [label="Snr1.chunk0.sub0.run33\ntext 159..159\nspeakers -\nJoão self/default lines"];
  item_059 -> item_060 [label="bytecode next"];
  item_061 [label="Snr1.chunk0.sub0.run34\ntext 160..160\nspeakers -\nJoão self/default lines"];
  item_060 -> item_061 [label="bytecode next"];
  item_062 [label="Snr1.chunk0.sub0.run35\ntext 161..162\nspeakers 恩里克神父\n恩里克神父"];
  item_061 -> item_062 [label="bytecode next"];
  item_063 [label="Snr1.chunk0.sub0.run36\ntext 163..165\nspeakers 恩里克神父\n恩里克神父"];
  item_062 -> item_063 [label="bytecode next"];
  item_064 [label="Snr1.chunk0.sub0.run37\ntext 166..166\nspeakers 老水手洛克\n老水手洛克"];
  item_063 -> item_064 [label="bytecode next"];
  item_065 [label="Snr1.chunk0.sub0.short71\nshort text 167\n經常受到$s公爵的關照．"];
  item_064 -> item_065 [label="bytecode next"];
  item_066 [label="Snr1.chunk0.sub0.short72\nshort text 168\n洛克先生從公爵府來找您了．"];
  item_065 -> item_066 [label="bytecode next"];
  item_067 [label="Snr1.chunk0.sub0.short73\nshort text 169\n說起做生意，從本港買的岩鹽能在地中海賣高價．"];
  item_066 -> item_067 [label="bytecode next"];
  item_068 [label="Snr1.chunk0.sub0.short74\nshort text 170\n和塞維爾的陶瓷器，可以在兩地之間做生意．"];
  item_067 -> item_068 [label="bytecode next"];
  item_069 [label="Snr1.chunk0.sub0.short75\nshort text 171\n$n先生，對不起，好像您沒有船．"];
  item_068 -> item_069 [label="bytecode next"];
  item_070 [label="Snr1.chunk0.sub0.short76\nshort text 172\n請您有了船，再來吧！"];
  item_069 -> item_070 [label="bytecode next"];
  item_071 [label="Snr1.chunk0.sub0.short77\nshort text 173\n$n先生，洛克先生從公爵府來找您了．"];
  item_070 -> item_071 [label="bytecode next"];
  item_072 [label="Snr1.chunk0.sub0.short78\nshort text 174\n$n先生，有要代管的東西吧？"];
  item_071 -> item_072 [label="bytecode next"];
  item_073 [label="Snr1.chunk0.sub0.run38\ntext 175..175\nspeakers -\nJoão self/default lines"];
  item_072 -> item_073 [label="bytecode next"];
  item_074 [label="Snr1.chunk0.sub0.short79\nshort text 176\n公爵府管家的麥克先生，叫我等您來了，把花劍給您．"];
  item_073 -> item_074 [label="bytecode next"];
  item_075 [label="Snr1.chunk0.sub0.short80\nshort text 177\n費用已付，請拿走吧．"];
  item_074 -> item_075 [label="bytecode next"];
  item_076 [label="Snr1.chunk0.sub0.short81\nshort text 178\n對了，請注意，武器沒有裝佩是不能使用的．"];
  item_075 -> item_076 [label="bytecode next"];
  item_077 [label="Snr1.chunk0.sub0.short82\nshort text 179\n經常受到$s公爵的關照．"];
  item_076 -> item_077 [label="bytecode next"];
  item_078 [label="Snr1.chunk0.sub0.short83\nshort text 180\n洛克先生從公爵府來找您了．"];
  item_077 -> item_078 [label="bytecode next"];
  item_079 [label="Snr1.chunk0.sub0.short84\nshort text 181\n$n先生，如有為難事，就去酒館．"];
  item_078 -> item_079 [label="bytecode next"];
  item_080 [label="Snr1.chunk0.sub0.short85\nshort text 182\n因為聽說，公爵年輕時也得到過那家酒館女老闆的照顧．"];
  item_079 -> item_080 [label="bytecode next"];
  item_081 [label="Snr1.chunk0.sub0.short86\nshort text 183\n$n公子，真少見，穿著便服來的．"];
  item_080 -> item_081 [label="bytecode next"];
  item_082 [label="Snr1.chunk0.sub0.short87\nshort text 184\n您是$s家的人，快出海了吧？"];
  item_081 -> item_082 [label="bytecode next"];
  item_083 [label="Snr1.chunk0.sub0.short88\nshort text 185\n$n先生，有公告說要把您當作平民對待，是真的嗎？"];
  item_082 -> item_083 [label="bytecode next"];
  item_084 [label="Snr1.chunk0.sub0.run39\ntext 186..186\nspeakers -\nJoão self/default lines"];
  item_083 -> item_084 [label="bytecode next"];
  item_085 [label="Snr1.chunk0.sub0.short89\nshort text 187\n$n先生，請您一定找到傳說中普萊斯特·約翰國．"];
  item_084 -> item_085 [label="bytecode next"];
  item_086 [label="Snr1.chunk0.sub0.short90\nshort text 188\n$n先生，終於要出海了！"];
  item_085 -> item_086 [label="bytecode next"];
}
