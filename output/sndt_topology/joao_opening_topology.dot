  scene_00 [label="Snr1.chunk0.sub0.run0\ntext 0..0\nspeakers 管家麥克\n〔管家麥克〕\\n$n，很對不起，公爵有令，不許您進家門．"];
  scene_01 [label="Snr1.chunk0.sub0.run1\ntext 1..17\nspeakers $s公爵夫人, 老水手洛克\n〔$s公爵夫人〕\\n哎呀，$n，這事已聽你父親說了，突然要你走出家，真殘酷呀！"];
  scene_00 -> scene_01 [label="bytecode next"];
  scene_02 [label="Snr1.chunk0.sub0.run2\ntext 18..18\nspeakers 管家麥克\n〔管家麥克〕\\n$n，很對不起，公爵有令，不讓您進家門．"];
  scene_01 -> scene_02 [label="bytecode next"];
  scene_03 [label="Snr1.chunk0.sub0.run3\ntext 19..21\nspeakers 管家麥克\n〔管家麥克〕\\n$n，很對不起，公爵有令，不讓您進家門．"];
  scene_02 -> scene_03 [label="bytecode next"];
  scene_04 [label="Snr1.chunk0.sub0.run4\ntext 22..49\nspeakers $s公爵\n聽說父親叫我．"];
  scene_03 -> scene_04 [label="bytecode next"];
  scene_05 [label="Snr1.chunk0.sub0.run5\ntext 50..54\nspeakers $s公爵, 老水手洛克\n洛克，洛克在嗎？"];
  scene_04 -> scene_05 [label="bytecode next"];
  scene_06 [label="Snr1.chunk0.sub0.run6\ntext 55..55\nspeakers 紅鯨亭女老闆卡蕾珞娃\n$n，快回公爵府吧！"];
  scene_05 -> scene_06 [label="bytecode next"];
  scene_07 [label="Snr1.chunk0.sub0.run7\ntext 56..59\nspeakers 紅鯨亭女老闆卡蕾珞娃, 歌女路琪亞\n〔紅鯨亭女老闆卡蕾珞娃〕\\n哎喲，$n，真少見呀！"];
  scene_06 -> scene_07 [label="bytecode next"];
  scene_08 [label="Snr1.chunk0.sub0.run8\ntext 60..62\nspeakers 紅鯨亭女老闆卡蕾珞娃, 歌女路琪亞\n想起來了，$n，你家洛克先生正找您呢，聽說公爵叫您去．"];
  scene_07 -> scene_08 [label="bytecode next"];
  scene_09 [label="Snr1.chunk0.sub0.run9\ntext 63..63\nspeakers 歌女路琪亞\n太太要您晚上10點到12點之間去公爵府．"];
  scene_08 -> scene_09 [label="bytecode next"];
  scene_10 [label="Snr1.chunk0.sub0.run10\ntext 64..77\nspeakers 紅鯨亭女老闆卡蕾珞娃, 歌女路琪亞, 老水手洛克\n$n先生，到底發生什麼事啊？街坊都鬧翻天了！"];
  scene_09 -> scene_10 [label="bytecode next"];
  scene_11 [label="Snr1.chunk0.sub0.run11\ntext 78..82\nspeakers 老水手洛克, 歌女路琪亞\n但是要作為資金，還得再弄一些．"];
  scene_10 -> scene_11 [label="bytecode next"];
  scene_12 [label="Snr1.chunk0.sub0.run12\ntext 83..86\nspeakers 歌女路琪亞, 老水手洛克\n回來了．"];
  scene_11 -> scene_12 [label="bytecode next"];
  scene_13 [label="Snr1.chunk0.sub0.run13\ntext 91..91\nspeakers -\n不，家父政務繁忙，我又沒有航海經驗．"];
  scene_12 -> scene_13 [label="bytecode next"];
  scene_14 [label="Snr1.chunk0.sub0.run14\ntext 94..94\nspeakers -\n是嗎，主教大人，那我就回家了．"];
  scene_13 -> scene_14 [label="bytecode next"];
  scene_15 [label="Snr1.chunk0.sub0.run15\ntext 98..98\nspeakers -\n謝謝，那我就不客氣了．"];
  scene_14 -> scene_15 [label="bytecode next"];
  scene_16 [label="Snr1.chunk0.sub0.run16\ntext 99..100\nspeakers -\n不，我不能要主教大人的錢．"];
  scene_15 -> scene_16 [label="bytecode next"];
  scene_17 [label="Snr1.chunk0.sub0.run17\ntext 102..102\nspeakers -\n不，不能給主教大人添麻煩啊．"];
  scene_16 -> scene_17 [label="bytecode next"];
  scene_18 [label="Snr1.chunk0.sub0.run18\ntext 105..105\nspeakers -\n聽說主教大人找我有事．"];
  scene_17 -> scene_18 [label="bytecode next"];
  scene_19 [label="Snr1.chunk0.sub0.run19\ntext 107..107\nspeakers -\n主教大人，據我所知，您是在找航海者吧？"];
  scene_18 -> scene_19 [label="bytecode next"];
  scene_20 [label="Snr1.chunk0.sub0.run20\ntext 112..112\nspeakers 恩里克神父\n〔恩里克神父〕\\n是，主教大人．"];
  scene_19 -> scene_20 [label="bytecode next"];
  scene_21 [label="Snr1.chunk0.sub0.run21\ntext 116..121\nspeakers 恩里克神父\n什麼？要去日本！聽父親說，它在遙遠的東方，是個浮在大海上的美麗的島國．"];
  scene_20 -> scene_21 [label="bytecode next"];
  scene_22 [label="Snr1.chunk0.sub0.run22\ntext 122..124\nspeakers 老水手洛克\n少爺，您那麼輕易就答應下來，您真有把握嗎？"];
  scene_21 -> scene_22 [label="bytecode next"];
  scene_23 [label="Snr1.chunk0.sub0.run23\ntext 126..126\nspeakers -\n很可能是洛克吧．"];
  scene_22 -> scene_23 [label="bytecode next"];
  scene_24 [label="Snr1.chunk0.sub0.run24\ntext 128..128\nspeakers 老水手洛克\n喂，船造好了嗎？"];
  scene_23 -> scene_24 [label="bytecode next"];
  scene_25 [label="Snr1.chunk0.sub0.run25\ntext 135..135\nspeakers 老水手洛克\n少爺，沒有船怎能出海呀．去造船廠看看吧．"];
  scene_24 -> scene_25 [label="bytecode next"];
  scene_26 [label="Snr1.chunk0.sub0.run26\ntext 137..137\nspeakers -\n噢，有什麼事嗎？"];
  scene_25 -> scene_26 [label="bytecode next"];
  scene_27 [label="Snr1.chunk0.sub0.run27\ntext 138..138\nspeakers -\n對了，是想找個可靠的航海者吧．"];
  scene_26 -> scene_27 [label="bytecode next"];
  scene_28 [label="Snr1.chunk0.sub0.run28\ntext 139..139\nspeakers 老水手洛克\n少爺，沒有資金就無法出航．那家酒店的老闆娘曾經照顧過公爵，找她商量一下不好嗎？"];
  scene_27 -> scene_28 [label="bytecode next"];
  scene_29 [label="Snr1.chunk0.sub0.run29\ntext 140..140\nspeakers 老水手洛克\n少爺，您想弄出海的資金吧．那家酒店的老闆娘曾經照顧過公爵，找她商量一下不好嗎？"];
  scene_28 -> scene_29 [label="bytecode next"];
  scene_30 [label="Snr1.chunk0.sub0.run30\ntext 141..141\nspeakers 老水手洛克\n少爺，資金還是不夠啊．"];
  scene_29 -> scene_30 [label="bytecode next"];
  scene_31 [label="Snr1.chunk0.sub0.run31\ntext 142..157\nspeakers 老水手洛克, 恩里克神父\n少爺，目前準備做什麼？"];
  scene_30 -> scene_31 [label="bytecode next"];
  scene_32 [label="Snr1.chunk0.sub0.run32\ntext 158..158\nspeakers 老水手洛克\n船長，看來恩里克神父精通會計，請他作我們的會計好不好？"];
  scene_31 -> scene_32 [label="bytecode next"];
  scene_33 [label="Snr1.chunk0.sub0.run33\ntext 159..159\nspeakers -\n好吧，就這麼辦．"];
  scene_32 -> scene_33 [label="bytecode next"];
  scene_34 [label="Snr1.chunk0.sub0.run34\ntext 160..160\nspeakers -\n另外，請洛克當助手．"];
  scene_33 -> scene_34 [label="bytecode next"];
  scene_35 [label="Snr1.chunk0.sub0.run35\ntext 161..162\nspeakers 恩里克神父\n對了，我還記得些以前靠過的港口的物價．"];
  scene_34 -> scene_35 [label="bytecode next"];
  scene_36 [label="Snr1.chunk0.sub0.run36\ntext 163..165\nspeakers 恩里克神父\n不，不好意思讓神父做這種工作．"];
  scene_35 -> scene_36 [label="bytecode next"];
  scene_37 [label="Snr1.chunk0.sub0.run37\ntext 166..166\nspeakers 老水手洛克\n船長，請恩里克神父當會計，挺好的．"];
  scene_36 -> scene_37 [label="bytecode next"];
  scene_38 [label="Snr1.chunk0.sub0.run38\ntext 175..175\nspeakers -\n代管的東西？"];
  scene_37 -> scene_38 [label="bytecode next"];
  scene_39 [label="Snr1.chunk0.sub0.run39\ntext 186..186\nspeakers -\n啊，是的．從今以後，把我當作一個普通航海者好了．"];
  scene_38 -> scene_39 [label="bytecode next"];
}
